# ============================================================
# Qi-CRM — variabili d'ambiente (esempio)
# Copia questo file in `.env.local` e compila i valori.
# Senza queste variabili l'app gira in MODALITÀ DEMO (dati mock
# in localStorage) — perfetta per provarla subito senza backend.
# ============================================================

# --- Supabase (backend dati) ---
# Lasciare vuoto/placeholder per restare in modalità demo (USING_MOCK = true).
# Compilare per collegare un progetto Supabase reale.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- AI cloud (opzionale) ---
# L'AI locale usa Gemini Nano (window.ai) su Chrome, senza chiavi.
# Questa chiave è opzionale, per un eventuale provider cloud di fallback.
VITE_OPENAI_API_KEY=
